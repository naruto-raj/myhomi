# =============================================================================
# Root .env — used by the web (Vite) and forwarded into the server container.
# Copy this to `.env` and fill in YOUR OWN values.
#   cp .env.example .env
#
# ⚠️  BRING YOUR OWN KEYS. No keys are shipped with this repo. If you got
#     this repo from someone, do NOT reuse their keys — each service is
#     rate-limited per account and quota is tied to the registering email.
#     All keys below are on free tiers; signing up takes 2–5 min each.
#     See README.md → "🔑 API keys" for the decision tree.
# =============================================================================

# --- REQUIRED ---------------------------------------------------------------

# MapLibre style URL. Sign up free at https://www.maptiler.com/ and pick a
# style (e.g. "Streets"). Copy the JSON style URL (not the preview URL).
VITE_MAP_STYLE_URL=https://api.maptiler.com/maps/streets/style.json?key=YOUR_MAPTILER_KEY

# Zoom threshold for switching between sector_stats (national) and
# sector_centroids (viewport) ranking modes.
VITE_ZOOM_THRESHOLD=8

# --- REQUIRED for commute features ------------------------------------------

# OpenRouteService API key — free tier (2000 req/day) at
# https://openrouteservice.org/dev/#/signup
# Powers travel-time + distance lookups for everywhere outside London, and
# London fallback when TfL fails. Commute UI does not work without this.
ORS_API_KEY=

# --- REQUIRED for accurate London commute costs -----------------------------
#
# Transport for London API — free, unlimited.
# Register at https://api-portal.tfl.gov.uk/ → create an app → copy app_key.
# Without these, London public-transport trips fall back to distance-based
# estimates (not real fares), so the affordability ranking will be wrong
# for London users.
TFL_APP_ID=
TFL_APP_KEY=

# --- OPTIONAL (EPC floor-area enrichment) -----------------------------------

# EPC Open Data API — register at https://epc.opendatacommunities.org/
# Without these, EPC features are disabled. The server logs a warning but
# everything else works.
EPC_API_EMAIL=
EPC_API_KEY=
EPC_CACHE_TTL_DAYS=30

# --- DOCKER-ONLY (rarely changed) -------------------------------------------

ZOOM_THRESHOLD=8

# Architecture for the Postgres+PostGIS container.
# This line is automatically (re)written by scripts/setup.sh / setup.ps1
# based on `uname -m` / $env:PROCESSOR_ARCHITECTURE. You normally don't
# need to set it by hand. Defaults to linux/amd64 when unset.
#   Apple Silicon (M1/M2/M3/M4): linux/arm64
#   Intel Mac / Linux x86_64 / Windows x86_64: linux/amd64
#   Windows on ARM (Snapdragon X): linux/arm64
# DB_PLATFORM=linux/arm64
