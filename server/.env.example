# =============================================================================
# server/.env — used when running ingest scripts OUTSIDE Docker.
# When you run scripts via `docker compose run server ...`, the container's
# env (defined in docker-compose.yml) takes precedence and this file is ignored.
# =============================================================================

# Used only when scripts are run on the host machine (not inside Docker).
# Note the host port 55432 (docker-compose maps 55432:5432).
DATABASE_URL=postgres://housing_user:housing_pass@localhost:55432/housing_map

DATA_DIR=../data
PORT=5050
CORS_ORIGIN=http://localhost:5173

# Commute settings (used by services/commute.js)
COMMUTE_COST_PER_KM=0.35
COMMUTE_DAYS_PER_WEEK=5
COMMUTE_CACHE_TTL_DAYS=30
COMMUTE_MAX_ORIGINS=120
COMMUTE_BATCH_SIZE=50

# OpenRouteService — required only if you want commute routing
ORS_API_KEY=

# EPC Open Data — required only for floor-area enrichment
EPC_API_EMAIL=
EPC_API_KEY=
EPC_CACHE_TTL_DAYS=30
